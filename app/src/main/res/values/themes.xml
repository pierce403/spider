<resources xmlns:tools="http://schemas.android.com/tools">
  <style name="Theme.Urchin" parent="Theme.MaterialComponents.DayNight.NoActionBar">
    <item name="colorPrimary">@color/urchin_primary</item>
    <item name="colorPrimaryVariant">@color/urchin_primary_variant</item>
    <item name="colorSecondary">@color/urchin_secondary</item>
    <item name="colorSecondaryVariant">@color/urchin_secondary_variant</item>
    <item name="colorSurface">@color/urchin_surface</item>
    <item name="colorSurfaceVariant">@color/urchin_surface_variant</item>
    <item name="android:colorBackground">@color/urchin_background</item>
    <item name="colorOnPrimary">@color/urchin_on_primary</item>
    <item name="colorOnSecondary">@color/urchin_on_secondary</item>
    <item name="colorOnBackground">@color/urchin_on_background</item>
    <item name="colorOnSurface">@color/urchin_on_surface</item>
    <item name="android:statusBarColor" tools:targetApi="l">@color/urchin_background</item>
    <item name="android:navigationBarColor" tools:targetApi="o_mr1">@color/urchin_background</item>
    <item name="android:windowBackground">@color/urchin_background</item>
