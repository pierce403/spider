<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/drawerLayout"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/urchin_background">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
      android:id="@+id/toolbar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/urchin_surface"
      android:elevation="0dp"
      android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
      android:title="@string/app_name_header"
      app:navigationIconTint="@color/urchin_secondary"
      app:subtitleTextColor="@color/urchin_secondary"
      app:titleTextColor="@color/urchin_on_surface" />

    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="@color/urchin_stroke_soft" />

    <FrameLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1">

      <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/deviceList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="24dp" />

      <TextView
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/panel_surface_subtle"
        android:gravity="center"
        android:padding="20dp"
        android:text="@string/no_devices"
        android:textColor="@color/urchin_on_background"
        android:visibility="gone" />
    </FrameLayout>
  </LinearLayout>

  <ScrollView
    android:id="@+id/filterDrawer"
    android:layout_width="340dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="@color/urchin_surface"
    android:fillViewport="true">

    <LinearLayout
      android:id="@+id/filterDrawerContent"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingStart="16dp"
      android:paddingTop="20dp"
      android:paddingEnd="16dp"
      android:paddingBottom="24dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filters_panel_title"
        android:textColor="@color/urchin_secondary"
        android:textSize="20sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/scanStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/scan_inactive"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/permissionHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/urchin_on_background" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/permissionActionButton"
        style="@style/UrchinSecondaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/retry_scan" />

      <TextView
        android:id="@+id/hardwareSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/panel_surface_subtle"
        android:padding="14dp"
        android:textColor="@color/urchin_on_surface" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/source_label"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <RadioGroup
        android:id="@+id/sourceGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <RadioButton
          android:id="@+id/usbSource"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/usb_source_label"
          android:textColor="@color/urchin_on_surface" />

        <RadioButton
          android:id="@+id/networkSource"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/network_source_label"
          android:textColor="@color/urchin_on_surface" />
      </RadioGroup>

      <LinearLayout
        android:id="@+id/networkConfigGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="12dp">

          <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/networkHostInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/network_host"
            android:inputType="textUri"
            android:textColor="@color/urchin_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="10dp">

          <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/networkPortInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/network_port"
            android:inputType="number"
            android:textColor="@color/urchin_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>
      </LinearLayout>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/frequency_label"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <RadioGroup
        android:id="@+id/frequencyGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
          android:id="@+id/freq315"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/frequency_315"
          android:textColor="@color/urchin_on_surface" />

        <RadioButton
          android:id="@+id/freq433"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="16dp"
          android:text="@string/frequency_433"
          android:textColor="@color/urchin_on_surface" />
      </RadioGroup>

      <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/gainInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/gain_hint"
          android:inputType="number"
          android:textColor="@color/urchin_on_surface" />
      </com.google.android.material.textfield.TextInputLayout>

      <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/urchin_stroke_soft" />

      <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/filterInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/filter_hint"
          android:textColor="@color/urchin_on_surface"
          android:textColorHint="@color/urchin_secondary" />
      </com.google.android.material.textfield.TextInputLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/sort_label"
          android:textColor="@color/urchin_on_background" />

        <Spinner
          android:id="@+id/sortSpinner"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="8dp"
          android:layout_weight="1" />
      </LinearLayout>

      <CheckBox
        android:id="@+id/liveOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/live_only"
        android:textColor="@color/urchin_on_background" />

      <CheckBox
        android:id="@+id/starredOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/starred_only"
        android:textColor="@color/urchin_on_background" />

      <CheckBox
        android:id="@+id/batteryLowOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/battery_low_only"
        android:textColor="@color/urchin_on_background" />
    </LinearLayout>
  </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>
