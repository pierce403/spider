<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/spider_background"
  android:orientation="vertical">

  <com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/spider_surface"
    android:elevation="0dp"
    android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
    android:title="@string/diagnostics"
    app:navigationIconTint="@color/spider_secondary"
    app:titleTextColor="@color/spider_on_surface" />

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="@color/spider_stroke_soft" />

  <ScrollView
    android:id="@+id/diagnosticsScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:padding="16dp">

      <com.google.android.material.button.MaterialButton
        android:id="@+id/copyDebugReportButton"
        style="@style/SpiderSecondaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/copy_scan_debug_report" />

      <TextView
        android:id="@+id/diagnosticsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/panel_surface_subtle"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:textColor="@color/spider_on_surface"
        android:textIsSelectable="true" />
    </LinearLayout>
  </ScrollView>
</LinearLayout>
